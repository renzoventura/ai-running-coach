# AWS
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# DynamoDB
DYNAMODB_TABLE=ai-running-coach

# Bedrock model
MODEL_ID=au.anthropic.claude-haiku-4-5-20251001-v1:0

# KMS (for encrypting Garmin passwords at rest)
KMS_KEY_ID=your-kms-key-id-here

# Strava OAuth (create an app at https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret

# Frontend URL — used to redirect after Strava OAuth callback
FRONTEND_URL=http://localhost:3000

# Garmin dev credentials — used by seed_garmin_session.py only (not required in production)
GARMIN_EMAIL=your-garmin-email
GARMIN_PASSWORD=your-garmin-password
GARMIN_USER_ID=your-clerk-user-id
